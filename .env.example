# --- TELEGRAM CONFIG ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
ADMIN_ID=123456789
ADMIN_CHAT_ID=123456789
CHANNEL_ID=-1001234567890

# --- BLOCKCHAIN CONFIG ---
TREASURY_WALLET_ADDR=0xYOUR_TREASURY_WALLET
ALCHEMY_API_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# --- SUBSCRIPTION SETTINGS ---
SUBSCRIPTION_ETH_PRICE=0.01
SUBSCRIPTION_DAYS=30
TRACK_POLL_INTERVAL=30

# --- DATABASE CONFIG ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

# --- HOSTING CONFIG ---
PORT=5000
RENDER_APP_NAME=your-render-app-name

# --- BOT IDENTITY ---
BOT_NAME=ICEBOYS-IBS
BOT_VERSION=2.0-STABLE
LOG_LEVEL=INFO
SERVICE_MODE=production
AUTO_RESTART=true
